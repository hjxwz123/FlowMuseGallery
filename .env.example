# SQLite database file used by Prisma.
# The path is relative to `prisma/schema.prisma`.
DATABASE_URL="file:./data/flowmuse.sqlite"

# Server
PORT=3000
FRONTEND_PORT=3001
BACKEND_URL="http://127.0.0.1:3000"

# Local public URLs.
# `APP_PUBLIC_URL` is used to generate local `/uploads/...` asset URLs.
APP_PUBLIC_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:5173"

# Security key for encrypting locally stored API keys.
APP_ENCRYPTION_KEY="change-me-32-bytes-minimum-length"
